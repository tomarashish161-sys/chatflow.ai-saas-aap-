{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["email", "createdAt"]
    },
    "Bot": {
      "title": "Bot Configuration",
      "description": "Settings and config for a user's bot",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "persona": { "type": "string" },
        "color": { "type": "string" },
        "position": { "type": "string", "enum": ["left", "right"] },
        "greeting": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "name", "persona", "color", "position", "greeting", "createdAt"]
    },
    "Source": {
      "title": "Training Data Source",
      "description": "A URL, file, or text used to train the bot",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["urls", "files", "text"] },
        "value": { "type": "string" },
        "status": { "type": "string", "enum": ["processing", "trained", "error"] },
        "content": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "type", "value", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "bots/{botId}": {
      "schema": { "$ref": "#/entities/Bot" },
      "description": "Stores user bots"
    },
    "sources/{sourceId}": {
      "schema": { "$ref": "#/entities/Source" },
      "description": "Stores training sources"
    }
  }
}
